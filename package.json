{
  "name": "ppt-generator",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "description": "Slidev PPT Generator - Monorepo",
  "scripts": {
    "cleanup:dist": "rimraf --glob dist",
    "packages:build": "pnpm cleanup:dist && pnpm -r --filter=./artifact/* run build"
  },
  "devDependencies": {
    "@iconify-json/carbon": "^1.2.14",
    "@iconify-json/devicon": "^1.2.45",
    "@iconify-json/logos": "^1.2.9",
    "@iconify-json/ri": "^1.2.6",
    "@iconify-json/simple-icons": "^1.2.55",
    "@iconify-json/twemoji": "^1.2.4",
    "@slidev/cli": "^52.5.0",
    "@slidev/client": "^52.5.0",
    "@slidev/theme-default": "latest",
    "@slidev/theme-seriph": "latest",
    "@slidev/types": "0.22.7",
    "@types/node": "^22.18.12",
    "@unocss/preset-attributify": "^66.5.4",
    "@unocss/preset-icons": "^66.5.4",
    "@unocss/preset-uno": "^66.5.4",
    "@unocss/preset-web-fonts": "^66.5.4",
    "@vueuse/core": "^13.9.0",
    "@vueuse/motion": "^3.0.3",
    "playwright-chromium": "^1.56.1",
    "rimraf": "^6.0.1",
    "seedrandom": "^3.0.5",
    "typescript": "^5.9.3",
    "unocss": "^66.5.4",
    "vite": "^6.4.1",
    "vue": "^3.5.22"
  }
}
